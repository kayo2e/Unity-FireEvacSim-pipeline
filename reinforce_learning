"""
Re-Filly | Stage 2: Evacuation Guidance RL Environment
=======================================================
에이전트  : 건물 내 각 셀의 유도등
액션      : 각 유도등 방향 결정 (0=N, 1=S, 2=E, 3=W)
관측      : Grid 상태 (화재/연기/사람/유도등/지형)
보상      : 생존 탈출 인원 비율 - 화재 유도 페널티 - 타임아웃 페널티
시나리오  : 4단계 커리큘럼 (초기화재 → 확산 → 출구폐쇄 → 폭발붕괴)

의존성: pip install gymnasium numpy
"""

import numpy as np
import gymnasium as gym
from gymnasium import spaces
from typing import Optional
import random


# ──────────────────────────────────────────────────────────
# 셀 타입 상수
# ──────────────────────────────────────────────────────────
EMPTY    = 0   # 복도 (이동 가능)
WALL     = 1   # 벽
EXIT     = 2   # 출구
ELEVATOR = 3   # 엘리베이터 (이동 불가)
STAIR    = 4   # 계단 (이동 가능)
TOILET   = 5   # 화장실 (이동 가능)
ROOM     = 6   # 방 내부 (이동 가능)
OUTSIDE  = 9   # 건물 외부

WALKABLE = {EMPTY, EXIT, STAIR, TOILET, ROOM}

# 방향 상수
N, S, E, W = 0, 1, 2, 3
DIRECTION_DELTA = {
    N: (-1,  0),
    S: ( 1,  0),
    E: ( 0,  1),
    W: ( 0, -1),
}

# ──────────────────────────────────────────────────────────
# 상상관 2층 Grid Map (30 x 20)
# ──────────────────────────────────────────────────────────
