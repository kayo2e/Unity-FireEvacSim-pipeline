# 커리큘럼 래퍼: 성공률에 따라 단계 자동 승급
# ──────────────────────────────────────────────────────────
class CurriculumWrapper(gym.Wrapper):
    """
    에피소드 생존율이 threshold 이상이면 다음 시나리오로 자동 승급.
    """
    def __init__(self, threshold: float = 0.8, window: int = 20):
        self.current_scenario = 1
        env = ReFillyEnv(scenario=1)
        super().__init__(env)
        self.threshold = threshold
        self.window = window
        self.recent_rates = []

    def step(self, action):
        obs, reward, terminated, truncated, info = self.env.step(action)
        if terminated or truncated:
            self.recent_rates.append(info["survival_rate"])
            if len(self.recent_rates) > self.window:
                self.recent_rates.pop(0)
            avg = sum(self.recent_rates) / len(self.recent_rates)
            if (avg >= self.threshold
                    and self.current_scenario < 4
                    and len(self.recent_rates) == self.window):
                self.current_scenario += 1
                self.env = ReFillyEnv(scenario=self.current_scenario)
                print(f"\n[Curriculum] 시나리오 {self.current_scenario}단계로 승급! "
                      f"(평균 생존율 {avg:.1%})")
                self.recent_rates = []
        return obs, reward, terminated, truncated, info

    def reset(self, **kwargs):
        return self.env.reset(**kwargs)


