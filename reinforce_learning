# 출구 위치 목록
EXIT_POSITIONS = [
    (8, 11), (8, 12),        # EXIT A (우측 비상구)
    (22, 8), (22, 9), (22, 10),  # EXIT B (하단 계단)
]

# 복도 셀만 추출 (에이전트 초기 위치 / 화재 초기 위치 후보)
def get_walkable_cells(grid):
    cells = []
    rows, cols = grid.shape
    for r in range(rows):
        for c in range(cols):
            if grid[r, c] in WALKABLE and grid[r, c] != EXIT:
                cells.append((r, c))
    return cells


# ──────────────────────────────────────────────────────────
# 시나리오 설정 (4단계 커리큘럼)
# ──────────────────────────────────────────────────────────
